{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "Ollama_3090": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama 3090",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "models": {
        "qwen3.5:27b-18k": {
          "name": "qwen3.5:27b-18k"
        },
        "qwen3-coder-largectx": {
          "name": "qwen3-coder-largectx"
        }
      }
    },
    "Ollama_3060": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama 3060",
      "options": {
        "baseURL": "http://127.0.0.1:11435/v1"
      },
      "models": {
        "qwen3.5:9b-64k": {
          "name": "qwen3.5:9b-64k"
        }
      }
    }
  },
  "model": "Ollama_3090/qwen3-coder-largectx",
  "small_model": "Ollama_3060/qwen3.5:9b-64k",
  "default_agent": "companion",
  "agent": {
    "companion": {
      "mode": "primary",
      "model": "Ollama_3060/qwen3.5:9b-64k",
      "temperature": 0.2,
      "permission": {
        "task": {
          "*": "allow"
        }
      }
    },
    "architect": {
      "mode": "subagent",
      "model": "Ollama_3090/qwen3.5:27b-18k",
      "temperature": 0.4
    },
    "coder": {
      "mode": "subagent",
      "model": "Ollama_3090/qwen3-coder-largectx",
      "temperature": 0.1
    }
  },
  "default_agent": "companion"
}
